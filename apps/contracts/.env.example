# RPC Endpoints
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Block Explorer
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Deployer Private Key (NEVER COMMIT)
PRIVATE_KEY=

# ============================================
# DEPLOYMENT CONFIGURATION (Runtime Variables)
# ============================================
# These can be set in .env or passed at runtime.
# The deployment scripts will read these values.

# PAYOUT_ADDRESS - Address to receive mint payments
# - REQUIRED for mainnet (script will fail without it)
# - Optional for Sepolia (defaults to deployer address)
PAYOUT_ADDRESS=

# ROYALTY_RECEIVER - Address to receive royalties (ERC-2981)
# - Optional (defaults to PAYOUT_ADDRESS)
ROYALTY_RECEIVER=

# ROYALTY_BPS - Royalty basis points (100 = 1%)
# - Optional (default: 500 = 5%)
ROYALTY_BPS=500

# PRICE_PER_PACK_WEI - Price per card pack in wei
# - Optional (default: 30000000000000000 = 0.03 ETH)
PRICE_PER_PACK_WEI=30000000000000000

# ============================================
# MAINNET-ONLY OPTIONS
# ============================================

# PROMISE_NFT - "A Promise" NFT contract address for burn redemption
# - Optional (default: address(0) = skip burn adapter)
PROMISE_NFT=

# PROMISE_IS_721 - Set to "true" if Promise NFT is ERC721
# - Optional (default: true)
PROMISE_IS_721=true

# ============================================
# OTHER CONFIGURATION
# ============================================

# Chainlink VRF (if using VRF mode for randomness)
VRF_COORDINATOR=0x271682DEB8C4E0901D1a1550aD2e64D568E69909
VRF_KEY_HASH=0x8af398995b04c28e9951adb9721ef74c74f93e6a478f39e7e0777be13527e7ef
VRF_SUBSCRIPTION_ID=
VRF_CALLBACK_GAS_LIMIT=200000

# External Collections for Burn Redeem (comma-separated)
ELIGIBLE_BURN_COLLECTIONS=
BURN_ADAPTER_TYPES=

# Fortune Configuration
FORTUNE_BASE_BG_CID=bafybeih3foatdgwucci5whnyhewkpc7c7w4y37birvsla6gjrdmg7d62va
